generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// IDENTITY & KYC
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  piUid         String?  @unique
  piUsername    String?
  piAccessToken String?

  // Sovereign DID
  did       String?  @unique
  didMethod String?  @default("did:axiom")

  // KYC
  kycStatus      KYCStatus @default(NONE)
  kycProvider    String?   // "pi_network" | "world_id" | "gitcoin"
  kycAssurance   String?   // "low" | "substantial" | "high"
  kycUidHash     String?   // privacy-preserving hash
  kycVerifiedAt  DateTime?

  // Agent
  agent      UserAgent?

  // Actions
  actions     Action[]
  xpLedger    XpLedger[]

  // Payments
  payments       PiPayment[]

  // Agent Logs
  agentLogs   AgentLog[]

  // Metadata
  metadata   String? // JSON: arbitrary user metadata
  lastActive DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum KYCStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// ─────────────────────────────────────────────
// AGENT SYSTEM
// ─────────────────────────────────────────────

model UserAgent {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicId    String    @unique @default(cuid()) // ag_xxx

  // Identity
  name        String    @default("My Agent")
  description String?
  avatarUrl   String?
  did         String?

  // State
  status      AgentStatus @default(INACTIVE) // inactive | active | paused | sleeping
  mode        AgentMode   @default(AUTONOMOUS) // autonomous | supervised | manual

  // Runtime
  lastActive   DateTime?
  lastHeartbeat DateTime?
  activeUntil  DateTime?
  memoryLimit  Int      @default(500) // max memory entries

  // Logs
  agentLogs   AgentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgentStatus {
  INACTIVE
  ACTIVE
  PAUSED
  SLEEPING
}

enum AgentMode {
  AUTONOMOUS
  SUPERVISED
  MANUAL
}

// ─────────────────────────────────────────────
// PI BLOCKCHAIN PAYMENTS
// ─────────────────────────────────────────────

model PiPayment {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId     String   @unique // Pi Network payment ID
  txid          String?  // blockchain transaction hash
  amount        Float
  memo          String?
  metadata      String?  // JSON: { skillId, agentId, purpose }
  status        String   @default("pending") // pending | approved | completed | cancelled | failed
  fromAddress   String?
  toAddress     String?
  network       String   @default("pi")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// ACTIONS & XP LEDGER
// ─────────────────────────────────────────────

model Action {
  id        String   @id @default(uuid())
  type      String   // "connect_twitter" | "daily_pow" | "verify_identity" | "forge_agent"
  xp        Int
  metadata  String?  // JSON: extra context
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], name: "user_action_unique")
  @@index([userId])
  @@index([type])
}

model XpLedger {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int      // positive = earned, negative = spent
  reason    String   // "action_claim" | "agent_create" | "admin_adjust"
  reference String?  // JSON: { actionId, agentId }
  balance   Int      // running balance after this entry
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// AGENT LOGS
// ─────────────────────────────────────────────

model AgentLog {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId     String?
  agent       UserAgent? @relation(fields: [agentId], references: [id])
  level       String     @default("info") // "debug" | "info" | "warn" | "error" | "critical"
  source      String     // "system" | "agent" | "skill" | "tool" | "user" | "payment"
  message     String
  metadata    String?    // JSON
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([agentId])
  @@index([level])
  @@index([createdAt])
}
