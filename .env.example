# =============================================================================
# AxiomID (L0 Authority) — environment contract
# =============================================================================
# Copy this file to `.env.local` for local development, or set the same keys
# in the Vercel project (Settings -> Environment Variables) for Preview /
# Production deployments. NEVER commit a populated `.env*` file.

# -----------------------------------------------------------------------------
# Public site config (safe to expose client-side)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://axiomid.app
NEXT_PUBLIC_APP_NAME=AxiomID
NEXT_PUBLIC_APP_DESCRIPTION=The Human Authorization Protocol

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/axiomid?schema=public

# -----------------------------------------------------------------------------
# Pi Network — L0 domain claim + payment verification
# -----------------------------------------------------------------------------
# 1. PI_API_KEY (server-side only):
#    Used to verify Pi payments and call the Pi Platform API. Issued in the Pi
#    Developer Portal under your app. Treat it like a database password.
PI_API_KEY=

# 2. PI_WALLET_PRIVATE_SEED (server-side only, OPTIONAL):
#    Stellar-format seed (starts with `S`) for the wallet that signs
#    server-side Pi transactions (e.g. completing app-to-user payments).
PI_WALLET_PRIVATE_SEED=

# 3. Sandbox vs mainnet (client + server)
#    Set to `true` to point the Pi SDK at the Pi Sandbox environment. This is
#    still real Pi Browser/App Studio authentication against Pi's sandbox.
NEXT_PUBLIC_PI_SANDBOX=false

# 4. Demo wallet fallback (client-side, LOCAL DEVELOPMENT ONLY)
#    Set to `true` only when developing outside Pi Browser and you explicitly
#    want a synthetic `demo:` wallet. Production builds never persist demo
#    wallets; App Studio/Pi Browser deployments must use Pi auth instead.
NEXT_PUBLIC_ENABLE_DEMO_WALLET=false

# 5. Development URL for Pi Sandbox communication
NEXT_PUBLIC_DEV_URL=

# -----------------------------------------------------------------------------
# CSRF Protection (server-side)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
OAUTH_STATE_SECRET=replace-me-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# VC Issuer Keys (server-side, Ed25519)
# -----------------------------------------------------------------------------
# Generate with: openssl genpkey -algorithm Ed25519 -out issuer_private.pem
# Extract public: openssl pkey -in issuer_private.pem -pubout -out issuer_public.pem
ISSUER_PRIVATE_KEY=
ISSUER_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Optional: Groq API (for curiosity-engine LLM inference)
# -----------------------------------------------------------------------------
GROQ_API_KEY=
